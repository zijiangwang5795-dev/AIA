# ── 服务配置 ──────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRE=2h
REFRESH_EXPIRE=30d

# ── 数据库 ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_assistant
REDIS_URL=redis://localhost:6379

# ── OpenClaw 网关（推荐：所有 AI 调用统一经此路由）──────
# 在服务器上部署 OpenClaw，后端通过此地址接入
# 参考：https://github.com/openclaw/openclaw
OPENCLAW_URL=http://localhost:18789    # 平台共享 OpenClaw 地址（免费用户接入点）
OPENCLAW_TOKEN=                        # 可选，gateway.auth.mode 启用时填写
OPENCLAW_DEFAULT_MODEL=deepseek-chat   # OpenClaw 内默认路由的模型
OPENCLAW_EMBED_MODEL=text-embedding-3-small  # 情节记忆向量化模型
# 注：接入模式（shared/dedicated）由用户订阅等级自动决定，无需手动配置

# ── AI 模型直连（不使用 OpenClaw 时）──────────────────
#
# 【直连模式】：不配置 OPENCLAW_URL，后端自动降级直连大模型 API
#   只需填写对应的 API Key，OPENCLAW_* 留空即可
#
# 默认直连模型（未设置 OPENCLAW_URL 时生效）：
DIRECT_MODEL=deepseek-chat           # 可选：deepseek-chat / gpt-4o-mini / deepseek-reasoner
#
# DeepSeek（推荐，性价比最高）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
#
# 【网关模式】：配置 OPENCLAW_URL，所有 AI 调用经 OpenClaw 路由
# OPENCLAW_URL 已配置时，上面的 API Keys 由 OpenClaw 侧管理，此处可留空

# ── 第三方 OAuth（可选，Demo 模式下不需要）─────────────
# 微信公众号 OAuth（用于微信内 H5 登录）
# 申请地址：https://mp.weixin.qq.com → 开发 → 基本配置
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_SECRET=your-wechat-app-secret
# 微信回调需要填写服务器的公网地址（微信要求 HTTPS 或已验证域名）
# 同时在公众号后台"网页授权域名"中配置此域名
BACKEND_URL=https://your-domain.com      # OAuth callback 基础地址
FRONTEND_URL=https://your-domain.com     # 登录完成后跳回的前端地址（默认与 BACKEND_URL 相同）
APPLE_TEAM_ID=
APPLE_KEY_ID=
GOOGLE_CLIENT_ID=

# ── HTTPS & HSTS ─────────────────────────────────────
# 仅在生产 HTTPS 部署时设为 true，否则浏览器会把 HTTP 请求强制升级为 HTTPS
# Demo / 局域网 HTTP 环境必须保持 false（默认值）
FORCE_HTTPS=false

# ── 安全 & CORS ──────────────────────────────────────
# 生产环境：逗号分隔允许的前端域名（NODE_ENV=production 时生效）
# 例：ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=

# 管理员用户 UUID（逗号分隔），空值时所有人均无法访问 /admin/*
# 例：ADMIN_USER_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ADMIN_USER_IDS=

# 内部服务 API 密钥（/push/send 端点校验）
# 仅后端内部任务调用时使用，客户端不可见
# 生产环境使用：openssl rand -hex 32
INTERNAL_API_SECRET=change-this-to-random-hex-in-production

# 非 Stripe 支付（微信/支付宝）Webhook HMAC 签名密钥
# 用于验证第三方支付回调的 X-Payment-Signature 头
# 生产环境使用：openssl rand -hex 32
PAYMENT_WEBHOOK_SECRET=change-this-to-random-hex-in-production

# 应用公网地址（Stripe 回调 URL、OAuth 回调等均依赖此地址）
APP_URL=https://your-domain.com

# ── 推送通知 — Firebase Cloud Messaging ──────────────
# Firebase Admin SDK 服务账号 JSON（将整个 JSON 压缩为单行字符串）
# 获取方式：Firebase 控制台 → 项目设置 → 服务账号 → 生成新私钥
# 示例：FIREBASE_CREDENTIALS={"type":"service_account","project_id":"xxx","private_key":"-----BEGIN RSA PRIVATE KEY-----\n..."}
FIREBASE_CREDENTIALS=

# ── 短信服务 ─────────────────────────────────────────
# 方案一：阿里云 SMS（国内推荐）
# 申请地址：https://www.aliyun.com/product/sms
ALIYUN_SMS_KEY=your-aliyun-access-key-id
ALIYUN_SMS_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN=AI助手               # 已审核的短信签名
ALIYUN_SMS_TEMPLATE=SMS_000000000     # 已审核的模板 CODE（含 ${code} 变量）

# 方案二：Twilio（国际 / 备用）
# 申请地址：https://www.twilio.com
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your-twilio-auth-token
TWILIO_FROM=+1xxxxxxxxxx              # 已购买的 Twilio 号码

# ── 支付 — Stripe ─────────────────────────────────────
# Stripe 账号注册：https://dashboard.stripe.com
# 测试密钥（sk_test_...）vs 正式密钥（sk_live_...）
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Stripe Webhook 签名密钥（在 Dashboard → Webhooks → 查看签名密钥）
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# 注：还需在 plans 表的 stripe_price_id 字段中填写对应 Stripe Price ID

# ── 搜索 API（可选，供 web_search 工具使用）────────────
SERPER_API_KEY=your-serper-api-key
TAVILY_API_KEY=your-tavily-api-key

# ── 演示模式（true = 跳过真实 OAuth，允许任意 OTP）────
# 生产环境务必设置 DEMO_MODE=false
DEMO_MODE=true
DEMO_OTP=123456
