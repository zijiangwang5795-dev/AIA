# ── 服务配置 ──────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRE=2h
REFRESH_EXPIRE=30d

# ── 数据库 ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_assistant
REDIS_URL=redis://localhost:6379

# ── OpenClaw 网关（推荐：所有 AI 调用统一经此路由）──────
# 在服务器上部署 OpenClaw，后端通过此地址接入
# 参考：https://github.com/openclaw/openclaw
OPENCLAW_URL=http://localhost:18789    # 平台共享 OpenClaw 地址（免费用户接入点）
OPENCLAW_TOKEN=                        # 可选，gateway.auth.mode 启用时填写
OPENCLAW_DEFAULT_MODEL=deepseek-chat   # OpenClaw 内默认路由的模型
OPENCLAW_EMBED_MODEL=text-embedding-3-small  # 情节记忆向量化模型
# 注：接入模式（shared/dedicated）由用户订阅等级自动决定，无需手动配置

# ── AI 模型直连（不使用 OpenClaw 时）──────────────────
#
# 【直连模式】：不配置 OPENCLAW_URL，后端自动降级直连大模型 API
#   只需填写对应的 API Key，OPENCLAW_* 留空即可
#
# 默认直连模型（未设置 OPENCLAW_URL 时生效）：
DIRECT_MODEL=deepseek-chat           # 可选：deepseek-chat / gpt-4o-mini / deepseek-reasoner
#
# DeepSeek（推荐，性价比最高）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
#
# 【网关模式】：配置 OPENCLAW_URL，所有 AI 调用经 OpenClaw 路由
# OPENCLAW_URL 已配置时，上面的 API Keys 由 OpenClaw 侧管理，此处可留空

# ── 第三方 OAuth（可选，Demo 模式下不需要）─────────────
# 微信公众号 OAuth（用于微信内 H5 登录）
# 申请地址：https://mp.weixin.qq.com → 开发 → 基本配置
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_SECRET=your-wechat-app-secret
# 微信回调需要填写服务器的公网地址（微信要求 HTTPS 或已验证域名）
# 同时在公众号后台"网页授权域名"中配置此域名
BACKEND_URL=https://your-domain.com      # OAuth callback 基础地址
FRONTEND_URL=https://your-domain.com     # 登录完成后跳回的前端地址（默认与 BACKEND_URL 相同）
APPLE_TEAM_ID=
APPLE_KEY_ID=
GOOGLE_CLIENT_ID=

# ── 演示模式（true = 跳过真实 OAuth，允许任意 OTP）────
DEMO_MODE=true
DEMO_OTP=123456
