# ── 服务配置 ──────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRE=2h
REFRESH_EXPIRE=30d

# ── 数据库 ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_assistant
REDIS_URL=redis://localhost:6379

# ── OpenClaw 网关（推荐：所有 AI 调用统一经此路由）──────
# 在服务器上部署 OpenClaw，后端通过此地址接入
# 参考：https://github.com/openclaw/openclaw
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=                              # 可选，gateway.auth.mode 启用时填写
OPENCLAW_MODE=dedicated                      # dedicated（每用户独占实例）或 shared（多用户共享 + agentId）
OPENCLAW_DEFAULT_MODEL=deepseek-chat         # OpenClaw 内默认路由的模型
OPENCLAW_EMBED_MODEL=text-embedding-3-small  # 情节记忆向量化模型

# ── AI 模型 API Keys（直连降级备用）────────────────────
# OPENCLAW_URL 已配置时，AI keys 由 OpenClaw 侧管理，此处可留空
# OPENCLAW_URL 未配置时，后端直接调用以下 API（兼容旧部署）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── 第三方 OAuth（可选，Demo 模式下不需要）─────────────
WECHAT_APP_ID=
WECHAT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
GOOGLE_CLIENT_ID=

# ── 演示模式（true = 跳过真实 OAuth，允许任意 OTP）────
DEMO_MODE=true
DEMO_OTP=123456
